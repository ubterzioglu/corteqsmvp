{
  "name": "corteqs-service-finder-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CorteQS Service Finder worker — claims jobs from Postgres, runs search/extract/classify providers, writes candidates and a cost ledger.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.json && node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  }
}
